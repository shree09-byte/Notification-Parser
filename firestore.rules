rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidNotification(data) {
      let requiredKeys = ['appName', 'titleText', 'body', 'persona', 'summary', 'category', 'priority', 'userId', 'createdAt'];
      
      return data.keys().hasAll(requiredKeys)
        && data.keys().size() <= 11
        && data.appName is string && data.appName.size() <= 200
        && data.titleText is string && data.titleText.size() <= 500
        && data.body is string && data.body.size() <= 10000
        && data.persona is string && data.persona.size() <= 100
        && data.summary is string && data.summary.size() <= 5000
        && data.category is string && data.category.size() <= 100
        && data.priority in ['CRITICAL', 'HIGH', 'NORMAL', 'LOW']
        && data.userId == request.auth.uid
        && ( !('actionItems' in data) || (data.actionItems is list && data.actionItems.size() <= 10 && (data.actionItems.size() == 0 || data.actionItems[0] is string)) )
        && ( !('suggestedReply' in data) || (data.suggestedReply is string && data.suggestedReply.size() <= 6000) );
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && isValidId(userId)
                    && isValidId(notificationId)
                    && isValidNotification(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn()
                    && request.auth.uid == userId
                    && isValidId(userId)
                    && isValidId(notificationId)
                    && isValidNotification(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(notificationId);
    }
  }
}
